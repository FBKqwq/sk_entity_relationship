{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LabelingFunctionOutput",
  "type": "object",
  "required": ["lf_name", "label", "vote", "confidence"],
  "properties": {
    "lf_name": {
      "type": "string"
    },
    "label": {
      "type": "string",
      "enum": [
        "diseases",
        "sub_diseases",
        "symptoms",
        "tests",
        "treatments",
        "plans",
        "methods",
        "etiologies",
        "pathogeneses"
      ]
    },
    "vote": {
      "type": "integer"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "count": {
      "type": "integer",
      "minimum": 0
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["start", "end", "text"],
        "properties": {
          "start": {
            "type": "integer",
            "minimum": 0
          },
          "end": {
            "type": "integer",
            "minimum": 0
          },
          "text": {
            "type": "string"
          },
          "source": {
            "type": ["string", "null"]
          }
        },
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
